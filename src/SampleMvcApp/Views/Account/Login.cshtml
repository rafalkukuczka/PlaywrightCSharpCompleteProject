@model LoginViewModel
@{
    ViewData["Title"] = "Log in";
}
<h1>Log in</h1>
<form method="post" asp-route-returnUrl="@ViewData["ReturnUrl"]" class="form-card">
    <div asp-validation-summary="ModelOnly" class="validation"></div>
    <label asp-for="Email"></label>
    <input asp-for="Email" />
    <span asp-validation-for="Email" class="validation"></span>

    <label asp-for="Password"></label>
    <input asp-for="Password" />
    <span asp-validation-for="Password" class="validation"></span>

    <label class="checkbox">
        <input asp-for="RememberMe" /> Remember me
    </label>

    <button type="submit">Log in</button>
</form>
@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
