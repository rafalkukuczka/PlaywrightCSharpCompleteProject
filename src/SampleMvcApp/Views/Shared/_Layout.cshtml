<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Sample MVC App</title>
    <link rel="stylesheet" href="~/css/site.css" />
</head>
<body>
<header class="topbar">
    <a class="brand" asp-controller="Home" asp-action="Index">Sample MVC App</a>
    <nav>
        <a asp-controller="Home" asp-action="Index">Home</a>
        <a asp-controller="Orders" asp-action="Index">Orders</a>
        @if (User.Identity?.IsAuthenticated == true)
        {
            <form method="post" asp-controller="Account" asp-action="Logout" class="inline-form">
                <button type="submit">Logout</button>
            </form>
        }
        else
        {
            <a asp-controller="Account" asp-action="Login">Log in</a>
        }
    </nav>
</header>
<main class="container">
    @RenderBody()
</main>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
